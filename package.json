{
  "name": "express-ts-drizzle",
  "version": "1.0.0",
  "description": "A starter template for building Express applications with TypeScript and Drizzle ORM",
  "author": "Deepesh Suraywanshi",
  "type": "module",
  "scripts": {
    "dev": "bun run src/server.ts",
    "build": "tsc",
    "start": "bun run dist/server.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/express": "^5.0.6",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "prettier": "^3.8.1"
  },
  "peerDependencies": {
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  }
}